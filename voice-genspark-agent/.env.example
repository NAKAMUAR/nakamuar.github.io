# Gemini API キー（無料取得: https://aistudio.google.com/apikey）
GEMINI_API_KEY=your_api_key_here

# 判断エンジンのモデル（無料枠は Flash-Lite 系を推奨）
GEMINI_MODEL=gemini-flash-lite-latest

# STT 設定
WHISPER_MODEL=small        # small / medium
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8  # CPU なら int8 が軽量
STT_LANGUAGE=ja

# 録音設定
SAMPLE_RATE=16000
RECORD_SECONDS=0           # 0 = Enter で開始/停止、>0 = 固定秒数録音
